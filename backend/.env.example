# Copy this file to .env in backend/ and customize.
# All variables prefixed with INTELLIYASH_ are picked up by app/config.py.

# INTELLIYASH_HOST=127.0.0.1
# INTELLIYASH_PORT=8000

# Remote fallback (optional). Off by default. NEVER enabled unless you set this.
# INTELLIYASH_ENABLE_CLOUD_FALLBACK=false
#
# Hugging Face (default, open-source):
# INTELLIYASH_CLOUD_PROVIDER=huggingface
# INTELLIYASH_HF_TOKEN=hf_...
# INTELLIYASH_HF_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct
#
# OpenAI alternative:
# INTELLIYASH_CLOUD_PROVIDER=openai
# INTELLIYASH_OPENAI_API_KEY=sk-...
# INTELLIYASH_CLOUD_MODEL=gpt-4o-mini
#
# Anthropic alternative:
# INTELLIYASH_CLOUD_PROVIDER=anthropic
# INTELLIYASH_CLOUD_API_KEY=sk-ant-...
# INTELLIYASH_CLOUD_MODEL=claude-haiku-4-5-20251001
#
# Google Gemini alternative:
# INTELLIYASH_CLOUD_PROVIDER=gemini
# INTELLIYASH_GEMINI_API_KEY=AIza...
# INTELLIYASH_GEMINI_MODEL=gemini-1.5-flash

# Inference defaults — usually overridden by SystemDetector at boot.
# INTELLIYASH_MAX_TOKENS=512
# INTELLIYASH_TEMPERATURE=0.7
# INTELLIYASH_IDLE_UNLOAD_SECONDS=300
